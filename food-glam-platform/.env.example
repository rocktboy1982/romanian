# ── Supabase Configuration ──
# Local dev: npx supabase status
# Production: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (server-side only, elevated permissions)
# WARNING: Keep this secret! Never commit to git.
# SUPABASE_SERVICE_KEY=your-service-key-here

# ── Application URL ──
# Local: http://127.0.0.1:3001
# Production: https://marechef.ro (or your Vercel URL)
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3001

# ── Google OAuth (production) ──
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Image Search API Keys (for scripts/upgrade-images-*.js) ──
# These are NOT needed at runtime — only for image upgrade scripts
# PEXELS_API_KEY=your-pexels-api-key
# UNSPLASH_ACCESS_KEY=your-unsplash-access-key
# PIXABAY_API_KEY=your-pixabay-api-key

# ── Google AdSense (production) ──
# NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-1860386577458088
