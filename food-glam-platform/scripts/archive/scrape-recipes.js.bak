// ── 13. TURKEY – yemek.com (JSON-LD×4 confirmed) ─────────────────────────────
async function scrapeTurkey() {
  return crawlAndScrape(
    [
      'https://www.yemek.com/tarif/corba/',
      'https://www.yemek.com/tarif/kahvalti/',
      'https://www.yemek.com/tarif/tavuk/',
      'https://www.yemek.com/tarif/et/',
      'https://www.yemek.com/tarif/tatli/',
      'https://www.yemek.com/tarif/sebze/',
      'https://www.yemek.com/tarif/balik/',
    ],
    (h) => {
      if (!h.includes('yemek.com/tarif/')) return false;
      const parts = h.split('/').filter(Boolean);
      if (parts.length < 3) return false;
      const cats = ['corba', 'kahvalti', 'tavuk', 'et', 'tatli', 'sebze', 'balik', 'pilav', 'salata', 'hamur-isleri', 'icki'];
      const last = parts[parts.length - 1];
      return !cats.includes(last);
    },
    20,
    'https://www.yemek.com'
  );
}

